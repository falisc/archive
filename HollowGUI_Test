UI = {}
UI.__index = UI

function UI:Window(opts)
    opts = opts or {}
    local W       = {}
    W.Title       = opts.Title    or "MatchaUI"
    W.Subtitle    = opts.Subtitle or ""
    W.Size        = opts.Size     or Vector2.new(750, 500)
    W.Key         = opts.Key      or 0xA1
    W._open       = true
    W._minimized  = false
    W._running    = true
    W._dragging   = false
    W._dragOff    = H.Vec2(0,0)
    W._pos        = H.Vec2(0,0)
    W._tabs       = {}
    W._activeTab  = nil
    W._drawings   = {}
    if opts.Theme and Themes[opts.Theme] then Theme = Themes[opts.Theme] end
    W._tracked    = { W.Key, 0x1B }
    W._topTabs    = opts.TopTabs == true
    local _openProg = 0
    local _minProg  = 1

    local SB    = W._topTabs and 0 or 180   -- no sidebar in TopTabs mode
    local TH    = 46                          -- title bar height
    local TTH   = W._topTabs and 38 or 0    -- tab strip height (TopTabs only)
    local P     = Theme.Padding
    local CR    = (opts.Rounded == false) and 0 or Theme.Corner
    local vp  = game:GetService("Workspace").CurrentCamera.ViewportSize
    W._pos    = H.Vec2(vp.X/2 - W.Size.X/2, vp.Y/2 - W.Size.Y/2)

    local dBg   = H.Sq(10) ; dBg.Color   = Theme.Background ; W._drawings.bg   = dBg
    local dTop  = H.Sq(11) ; dTop.Color  = Theme.TopBar      ; W._drawings.top  = dTop
    local dTopF = H.Sq(11,true,0) ; dTopF.Color = Theme.TopBar ; W._drawings.topF = dTopF
    local dSide = H.Sq(11,true,CR) ; dSide.Color = Theme.Sidebar ; W._drawings.side = dSide
    local dSideTop = H.Sq(11,true,0) ; dSideTop.Color = Theme.Sidebar ; W._drawings.sideTop = dSideTop
    local dSideB= H.Sq(12,true,0) ; dSideB.Color= Theme.Border ; W._drawings.sideB= dSideB
    local dTtl  = H.Txt(13,Theme.TitleSize) ; dTtl.Color=Theme.Text    ; dTtl.Text=W.Title    ; W._drawings.ttl=dTtl
    local dSub  = H.Txt(13,Theme.TitleSize-2) ; dSub.Color=Theme.SubText ; dSub.Text=W.Subtitle ; W._drawings.sub=dSub
    local dCls  = H.Sq(13,true,CR)  ; dCls.Color = Theme.CloseBtn   ; W._drawings.cls  = dCls
    local dCX1  = H.Ln(14,2)       ; dCX1.Color = Theme.Text        ; W._drawings.cx1  = dCX1
    local dCX2  = H.Ln(14,2)       ; dCX2.Color = Theme.Text        ; W._drawings.cx2  = dCX2
    local dMin    = H.Sq(13,true,CR) ; dMin.Color = Theme.MinimizeBtn ; W._drawings.min    = dMin
    -- Double-square restore icon: back square (filled) + front square (outline via 4 lines)
    local dMinSqB = H.Sq(14,true,2)  ; dMinSqB.Color = Theme.MinimizeBtn ; W._drawings.minSqB = dMinSqB  -- back filled
    local dMinSqF = H.Sq(14,false,2) ; dMinSqF.Color = Theme.Text        ; W._drawings.minSqF = dMinSqF  -- front outline
    local dMinSqBo= H.Sq(15,false,2) ; dMinBo_color = Theme.Text ; dMinSqBo.Color = Theme.Text ; W._drawings.minSqBo= dMinSqBo -- back outline
    local dSep  = H.Ln(12,1)       ; dSep.Color = Theme.Border      ; W._drawings.sep  = dSep

    -- TopTabs: horizontal tab strip background + bottom separator
    local dTabStrip    = H.Sq(11,true,0)  ; dTabStrip.Color = Theme.Sidebar    ; W._drawings.tabStrip    = dTabStrip
    local dTabStripSep = H.Ln(12,1)       ; dTabStripSep.Color = Theme.Border  ; W._drawings.tabStripSep = dTabStripSep

    -- Ghost logo: body (rounded square), two eyes (circles), three skirt triangles
    local dGhostBody  = H.Sq(13,true,8)  ; dGhostBody.Color  = Theme.Accent  ; W._drawings.ghostBody  = dGhostBody
    local dGhostEyeL  = H.Circ(14)       ; dGhostEyeL.Color  = Theme.TopBar  ; dGhostEyeL.NumSides=20 ; dGhostEyeL.Radius=2.5 ; W._drawings.ghostEyeL  = dGhostEyeL
    local dGhostEyeR  = H.Circ(14)       ; dGhostEyeR.Color  = Theme.TopBar  ; dGhostEyeR.NumSides=20 ; dGhostEyeR.Radius=2.5 ; W._drawings.ghostEyeR  = dGhostEyeR
    -- Three bottom triangles cut into the skirt (TopBar color to fake cutouts)
    local dGhostSkL   = Drawing.new("Triangle") ; dGhostSkL.Filled=true ; dGhostSkL.Color=Theme.TopBar ; dGhostSkL.ZIndex=14 ; dGhostSkL.Visible=false ; W._drawings.ghostSkL = dGhostSkL
    local dGhostSkM   = Drawing.new("Triangle") ; dGhostSkM.Filled=true ; dGhostSkM.Color=Theme.TopBar ; dGhostSkM.ZIndex=14 ; dGhostSkM.Visible=false ; W._drawings.ghostSkM = dGhostSkM
    local dGhostSkR   = Drawing.new("Triangle") ; dGhostSkR.Filled=true ; dGhostSkR.Color=Theme.TopBar ; dGhostSkR.ZIndex=14 ; dGhostSkR.Visible=false ; W._drawings.ghostSkR = dGhostSkR

    local dPlrBg      = H.Sq(12,true,CR) ; dPlrBg.Color = Theme.TabActive ; W._drawings.plrBg      = dPlrBg
    local dPlrBgFix   = H.Sq(12,true,0)  ; dPlrBgFix.Color = Theme.TabActive ; W._drawings.plrBgFix   = dPlrBgFix
    local dPlrBgFixBR = H.Sq(12,true,0)  ; dPlrBgFixBR.Color = Theme.TabActive ; W._drawings.plrBgFixBR = dPlrBgFixBR
    local dPlrIcon    = H.Sq(13,true,CR)  ; dPlrIcon.Color  = Theme.Accent   ; W._drawings.plrIcon    = dPlrIcon
    local dPlrInitial = H.Txt(14,12)                ; dPlrInitial.Color = Theme.Text   ; W._drawings.plrInitial = dPlrInitial

    local _userName = tostring(LocalPlayer.Name)
    local _dispName = _userName
    pcall(function()
        local dn = tostring(LocalPlayer.DisplayName)
        if dn and dn ~= "" and dn ~= "nil" then _dispName = dn end
    end)

    local dPlrName = H.Txt(13,13) ; dPlrName.Color = Theme.Text    ; W._drawings.plrName = dPlrName
    local dPlrDisp = H.Txt(13,10) ; dPlrDisp.Color = Theme.SubText ; W._drawings.plrDisp = dPlrDisp
    -- Spoof button: small square on right side of player card, no text
    local dPlrSpoof = H.Sq(13,true,CR) ; dPlrSpoof.Color = Theme.MinimizeBtn ; W._drawings.plrSpoof = dPlrSpoof
    local _plrSpoofed = false
    local _plrSpoofRect = {pos=H.Vec2(0,0), size=H.Vec2(18,18)}

    dPlrName.Text    = _dispName
    dPlrDisp.Text    = "@".._userName
    dPlrInitial.Text = string.upper(string.sub(_dispName, 1, 1))

    local clsR = {pos=H.Vec2(0,0), size=H.Vec2(18,18)}
    local minR = {pos=H.Vec2(0,0), size=H.Vec2(18,18)}

    W._draw = function()
        local pos  = W._pos
        local sz   = W.Size

        _openProg = _openProg + ((W._open and 1 or 0) - _openProg) * 0.07
        _minProg  = _minProg  + ((W._minimized and 0 or 1) - _minProg) * 0.1

        local fade   = _openProg
        local isVis  = _openProg > 0.01
        local bodyH  = (sz.Y - TH - TTH) * _minProg
        local totalH = TH + TTH + bodyH
        local vis    = isVis and _minProg > 0.01
        local btn    = H.Vec2(18,18)

        local function f(d) if d.Visible then d.Transparency = fade end end
        local function ft(d) if d.Visible then d.Transparency = 1 end end

        dBg.Position  = pos
        dBg.Size      = H.Vec2(sz.X, totalH)
        dBg.Corner    = CR
        dBg.Visible   = isVis; f(dBg)

        dTop.Position = pos; dTop.Size = H.Vec2(sz.X, TH); dTop.Corner = CR; dTop.Visible = isVis; f(dTop)
        -- Bottom half of topbar fill (covers rounded corners bleed). In TopTabs mode extend to cover tab strip too.
        local topFillH = W._topTabs and (TH/2 + TTH) or TH/2
        dTopF.Position= pos + H.Vec2(0,TH/2); dTopF.Size = H.Vec2(sz.X, topFillH); dTopF.Visible = isVis; f(dTopF)

        -- Sidebar (only in sidebar mode)
        if not W._topTabs then
            dSide.Position = pos + H.Vec2(0,TH); dSide.Size = H.Vec2(SB, bodyH); dSide.Corner = CR; dSide.Visible = vis; f(dSide)
            dSideTop.Position = pos + H.Vec2(0,TH); dSideTop.Size = H.Vec2(SB, CR*2); dSideTop.Visible = vis; f(dSideTop)
            dSideB.Position= pos + H.Vec2(SB,TH); dSideB.Size= H.Vec2(1,bodyH); dSideB.Visible= vis; f(dSideB)
        else
            dSide.Visible = false; dSideTop.Visible = false; dSideB.Visible = false
        end

        -- Tab strip (TopTabs mode only)
        if W._topTabs then
            -- Tab strip matches topbar color — seamless look
            dTabStrip.Position = pos + H.Vec2(0, TH)
            dTabStrip.Size     = H.Vec2(sz.X, TTH)
            dTabStrip.Color    = Theme.TopBar
            dTabStrip.Visible  = vis; f(dTabStrip)
            -- Only one separator: below the tab strip, above the content
            dTabStripSep.From  = pos + H.Vec2(0, TH + TTH)
            dTabStripSep.To    = pos + H.Vec2(sz.X, TH + TTH)
            dTabStripSep.Visible = vis; f(dTabStripSep)
        else
            dTabStrip.Visible = false; dTabStripSep.Visible = false
        end

        -- Ghost logo in top-left of topbar
        local gW, gH = 22, 26
        local gX = pos.X + P + 2
        local gY = pos.Y + TH/2 - gH/2
        dGhostBody.Position = H.Vec2(gX, gY); dGhostBody.Size = H.Vec2(gW, gH)
        dGhostBody.Color = Theme.Accent; dGhostBody.Visible = isVis; f(dGhostBody)
        dGhostEyeL.Position = H.Vec2(gX + 6,  gY + 9); dGhostEyeL.Visible = isVis; f(dGhostEyeL)
        dGhostEyeR.Position = H.Vec2(gX + 16, gY + 9); dGhostEyeR.Visible = isVis; f(dGhostEyeR)
        local skY = gY + gH; local skH = 6; local skW = gW / 3
        dGhostSkL.PointA=H.Vec2(gX,         skY-skH); dGhostSkL.PointB=H.Vec2(gX+skW,       skY); dGhostSkL.PointC=H.Vec2(gX,         skY)
        dGhostSkM.PointA=H.Vec2(gX+skW,     skY);     dGhostSkM.PointB=H.Vec2(gX+skW*1.5,   skY-skH); dGhostSkM.PointC=H.Vec2(gX+skW*2,   skY)
        dGhostSkR.PointA=H.Vec2(gX+skW*2,   skY);     dGhostSkR.PointB=H.Vec2(gX+gW,        skY-skH); dGhostSkR.PointC=H.Vec2(gX+gW,      skY)
        dGhostSkL.Visible=isVis; f(dGhostSkL)
        dGhostSkM.Visible=isVis; f(dGhostSkM)
        dGhostSkR.Visible=isVis; f(dGhostSkR)

        -- Title: shifted right of ghost
        local titleX = pos.X + P + gW + 12
        local titleY = pos.Y + TH/2 - Theme.TitleSize/2
        dTtl.Position = H.Vec2(titleX, titleY)
        dTtl.Visible  = isVis; ft(dTtl)

        -- Subtitle: same line as title, slightly smaller, faded
        if W.Subtitle ~= "" then
