local Input = {
    m1 = false, m1Last = false, m1Down = false, m1Up = false,
    keys = {}, keysLast = {}, keysDown = {},
}
function Input.Poll(tracked)
    Input.m1Last = Input.m1
    Input.m1     = ismouse1pressed()
    Input.m1Down = Input.m1 and not Input.m1Last
    Input.m1Up   = not Input.m1 and Input.m1Last
    local seen = {}
    for _, k in ipairs(tracked) do
        if not seen[k] then
            seen[k] = true
            Input.keysLast[k] = Input.keys[k]
            Input.keys[k]     = iskeypressed(k)
            Input.keysDown[k] = Input.keys[k] and not Input.keysLast[k]
        end
    end
end

