local Input = {
    m1=false, m1Last=false, m1Down=false, m1Up=false,
    keys={}, keysLast={}, keysDown={},
    _conns={},
}
table.insert(Input._conns, UIS.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        Input.m1 = true; Input.m1Down = true
    end
end))
table.insert(Input._conns, UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        Input.m1 = false; Input.m1Up = true
    end
end))
function Input.Poll(tracked)
    local active = true
    pcall(function() active = isrbxactive() end)
    local seen = {}
    for _, k in ipairs(tracked) do
        if not seen[k] then
            seen[k] = true
            Input.keysLast[k] = Input.keys[k]
            Input.keys[k]     = active and iskeypressed(k) or false
            Input.keysDown[k] = Input.keys[k] and not Input.keysLast[k]
        end
    end
end
function Input.Clear()
    Input.m1Down = false
    Input.m1Up   = false
end

