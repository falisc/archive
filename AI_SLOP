-- ─────────────────────────────────────────────────────────────
--  Drawing helpers
-- ─────────────────────────────────────────────────────────────
local H = {}
function H.V2(x, y)     return Vector2.new(x, y) end
function H.Mouse()       return H.V2(Mouse.X, Mouse.Y) end
function H.InRect(p, s)
    local m = H.Mouse()
    return m.X >= p.X and m.X <= p.X + s.X and m.Y >= p.Y and m.Y <= p.Y + s.Y
end
function H.Sq(z, filled, corner)
    local s = Drawing.new("Square")
    s.Filled  = filled ~= false
    s.ZIndex  = z or 0
    s.Corner  = corner or 0
    s.Visible = false
    return s
end
function H.Txt(z, size)
    local t = Drawing.new("Text")
    t.ZIndex   = z or 0
    t.Size     = size or Theme.FontSize
    t.Outline  = false
    t.Font     = Drawing.Fonts.SystemBold
    t.Visible  = false
    return t
end
function H.Ln(z, thick)
    local l = Drawing.new("Line")
    l.ZIndex     = z or 0
    l.Thickness  = thick or 1
    l.Visible    = false
    return l
end
function H.Tri(z)
    local t = Drawing.new("Triangle")
    t.Filled  = true
    t.ZIndex  = z or 0
    t.Visible = false
    return t
end
function H.Circ(z)
    local c = Drawing.new("Circle")
    c.Filled   = true
    c.ZIndex   = z or 0
    c.NumSides = 24
    c.Visible  = false
    return c
end
function H.InClip(py, ph, ct, cb)
    if not ct or not cb then return true end
    return (py + ph) > ct and py < cb
end
function H.TxtClip(py, fs, ct, cb)
    if not ct or not cb then return true end
    return (py + fs) <= cb and (py + fs) > ct
end

