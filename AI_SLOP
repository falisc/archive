--[[
    MatchaMenu - Matcha Cheat-Style UI Library
    Drawing-based renderer, Matcha-compatible (UserInputService + iskeypressed)

    STRUCTURE:
      Window  →  Tabs (horizontal)  →  SubTabs  →  Sections (two-column)  →  Widgets

    USAGE:
    ======

    local Window = Menu:Window({
        Title    = "Matcha",
        Subtitle = "Comfort",
        Tag      = "stable",
        Username = "whofal",
        Size     = Vector2.new(750, 560),
        Key      = 0xA1,  -- toggle key (default RightShift)
        Discord  = "matcha.pink/discord",
        Build    = "v1.12",
    })

    local Tab = Window:Tab({ Title = "Combat" })

    -- Sub-tabs (the second row of tabs inside the tab):
    local Sub = Tab:SubTab({ Title = "Aimbot" })

    -- Two-column layout:
    local Left, Right = Sub:Row()

    -- Or a full-width section (rare):
    local Full = Sub:Section()

    -- Widgets (all work in Left, Right, or Full):
    Left:Checkbox({ Title = "Enabled",     Key = 0x52 }, function(b) end)
    Left:Slider({   Title = "Distance", Min=0, Max=500, Default=100, Suffix="" }, function(n) end)
    Left:Dropdown({ Title = "Hit Part",  Options={"Head","Body","Legs"}, Default="Head" }, function(v) end)
    Left:Label({    Title = "Misc" })   -- section divider label

    -- Get / Set:
    local c = Left:Checkbox(...)  ; c:Get() ; c:Set(true)
    local s = Left:Slider(...)    ; s:Get() ; s:Set(50)
    local d = Left:Dropdown(...)  ; d:Get() ; d:Set("Body")

    Window:Toggle()        -- toggle visibility
    Window:Toggle(true/false)
    Window:SetKey(0xA1)
    Window:Unload()

    -- Theme switching:
    Window:SetTheme("Default")  -- "Default" | "Purple" | "Blue" | "Green" | "Gold"
    -- One-liner theme dropdown:
    Window:ThemeDropdown(someSection, "Theme")
]]

