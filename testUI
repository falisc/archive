--[[
    MatchaUI Library
    A clean, easy-to-use UI library for Matcha executor
    
    DOCUMENTATION:
    ==============
    
    -- Create a window
    local Window = UI:Window({
        Title = "My Script",
        Subtitle = "v1.0",
        Size = Vector2.new(750, 500),
        Key = Enum.KeyCode.RightShift, -- keybind to toggle
    })
    
    -- Create a tab
    local Tab = Window:Tab({ Title = "Movement" })
    
    -- Create a row (gives you Left and Right sections side by side)
    local Left, Right = Tab:Row({ Title = "Section Name" })
    -- OR if you want a full width section:
    local Full = Tab:Section({ Title = "Full Width" })
    
    -- Widgets (work on any section: Left, Right, or Full)
    Section:Label({ Title = "Some text" })
    Section:Button({ Title = "Click Me" }, function() end)
    Section:Toggle({ Title = "Enable thing", Default = false }, function(bool) end)
    Section:Slider({ Title = "Speed", Min = 0, Max = 100, Default = 50, Suffix = "%" }, function(num) end)
    Section:Dropdown({ Title = "Mode", Options = {"A","B","C"}, Default = "A" }, function(val) end)
    Section:MultiDropdown({ Title = "Items", Options = {"X","Y","Z"}, Default = {} }, function(tbl) end)
    Section:Keybind({ Title = "Teleport", Key = Enum.KeyCode.T }, function() end, function(key) end)
    
    -- Get/Set values
    local toggle = Section:Toggle(...)
    toggle:Get() -- returns bool
    toggle:Set(true)
    
    local slider = Section:Slider(...)
    slider:Get() -- returns number
    slider:Set(75)
    
    local label = Section:Label(...)
    label:Get() -- returns string
    label:Set("New text")
    
    local dropdown = Section:Dropdown(...)
    dropdown:Get() -- returns string
    dropdown:Set("B")
    
    local multi = Section:MultiDropdown(...)
    multi:Get() -- returns table
    multi:Set({"X", "Z"})
    multi:Add("Y")
    multi:Remove("X")
    multi:Toggle("Z")
    
    -- Unload UI
    Window:Unload()
    
    -- Toggle visibility
    Window:Toggle()
    Window:Toggle(true)  -- force open
    Window:Toggle(false) -- force close
]]

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- Theme
local Theme = {
    Background    = Color3.fromRGB(18, 18, 20),
    Sidebar       = Color3.fromRGB(23, 23, 26),
    TopBar        = Color3.fromRGB(23, 23, 26),
    Section       = Color3.fromRGB(28, 28, 32),
    SectionHeader = Color3.fromRGB(35, 35, 40),
    Accent        = Color3.fromRGB(100, 100, 220),
    AccentHover   = Color3.fromRGB(120, 120, 240),
    TabActive     = Color3.fromRGB(38, 38, 48),
    TabHover      = Color3.fromRGB(33, 33, 38),
    Text          = Color3.fromRGB(240, 240, 240),
    SubText       = Color3.fromRGB(160, 160, 170),
    ToggleOff     = Color3.fromRGB(60, 60, 70),
    ToggleOn      = Color3.fromRGB(100, 100, 220),
    SliderFill    = Color3.fromRGB(100, 100, 220),
    SliderBg      = Color3.fromRGB(45, 45, 55),
    Border        = Color3.fromRGB(45, 45, 55),
    CloseBtn      = Color3.fromRGB(200, 60, 60),
    MinimizeBtn   = Color3.fromRGB(60, 60, 70),
    Corner        = 6,
    Padding       = 8,
    FontSize      = 14,
    TitleSize     = 15,
}

-- Helpers
local H = {}

function H.Vec2(x, y) return Vector2.new(x, y) end

function H.MousePos()
    return H.Vec2(Mouse.X, Mouse.Y)
end

function H.InRect(pos, size)
    local m = H.MousePos()
    return m.X >= pos.X and m.X <= pos.X + size.X and m.Y >= pos.Y and m.Y <= pos.Y + size.Y
end

function H.TextSize(text, size)
    -- approximate: each char ~0.55x fontsize wide
    return H.Vec2(#text * (size or Theme.FontSize) * 0.55, size or Theme.FontSize)
end

function H.NewSquare(zindex, filled, corner)
    local s = Drawing.new("Square")
    s.Filled = filled ~= false
    s.ZIndex = zindex or 0
    s.Corner = corner or 0
    s.Visible = false
    return s
end

function H.NewText(zindex, size, outline)
    local t = Drawing.new("Text")
    t.ZIndex = zindex or 0
    t.Size = size or Theme.FontSize
    t.Outline = outline ~= false
    t.Visible = false
    return t
end

function H.NewLine(zindex, thickness)
    local l = Drawing.new("Line")
    l.ZIndex = zindex or 0
    l.Thickness = thickness or 1
    l.Visible = false
    return l
end

function H.NewCircle(zindex, filled)
    local c = Drawing.new("Circle")
    c.Filled = filled ~= false
    c.ZIndex = zindex or 0
    c.Visible = false
    return c
end

function H.OnDown(fn)
    return UserInputService.InputBegan:Connect(function(input, gpe)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            fn(input)
        end
    end)
end

function H.OnUp(fn)
    return UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            fn(input)
        end
    end)
end

function H.OnKey(fn)
    return UserInputService.InputBegan:Connect(function(input, gpe)
        fn(input)
    end)
end

function H.KeyName(key)
    if key == nil then return "NONE" end
    for name, val in Enum.KeyCode do
        if val == key then return name end
    end
    return "?"
end

function H.RemoveAll(drawings)
    for _, d in pairs(drawings) do
        if type(d) == "userdata" then
            pcall(function() d:Remove() end)
        end
    end
end

-- ============================================================
-- UI LIBRARY
-- ============================================================

UI = {}
UI.__index = UI

function UI:Window(opts)
    opts = opts or {}
    local W = {}

    W.Title      = opts.Title or "MatchaUI"
    W.Subtitle   = opts.Subtitle or ""
    W.Size       = opts.Size or Vector2.new(750, 500)
    W.Key        = opts.Key or Enum.KeyCode.RightShift

    local SIDEBAR_W  = 180
    local TOPBAR_H   = 38
    local PAD        = Theme.Padding

    W._open        = true
    W._minimized   = false
    W._running     = true
    W._dragging    = false
    W._dragOffset  = H.Vec2(0, 0)
    W._tabs        = {}
    W._activeTab   = nil
    W._connections = {}
    W._drawings    = {}

    -- Calculate starting position (centered)
    local vp = game:GetService("Workspace").CurrentCamera.ViewportSize
    W._pos = H.Vec2(vp.X / 2 - W.Size.X / 2, vp.Y / 2 - W.Size.Y / 2)

    -- ---- Drawings ----
    -- Main background
    local dBg = H.NewSquare(10, true, Theme.Corner)
    dBg.Color = Theme.Background
    W._drawings.bg = dBg

    -- Top bar
    local dTop = H.NewSquare(11, true, Theme.Corner)
    dTop.Color = Theme.TopBar
    W._drawings.top = dTop

    -- Top bar bottom fill (covers bottom corners)
    local dTopFill = H.NewSquare(11, true, 0)
    dTopFill.Color = Theme.TopBar
    W._drawings.topFill = dTopFill

    -- Sidebar
    local dSide = H.NewSquare(11, true, 0)
    dSide.Color = Theme.Sidebar
    W._drawings.side = dSide

    -- Sidebar right border
    local dSideBorder = H.NewSquare(12, true, 0)
    dSideBorder.Color = Theme.Border
    W._drawings.sideBorder = dSideBorder

    -- Title text
    local dTitle = H.NewText(13, Theme.TitleSize, true)
    dTitle.Color = Theme.Text
    dTitle.Text = W.Title
    W._drawings.title = dTitle

    -- Subtitle text
    local dSub = H.NewText(13, 11, true)
    dSub.Color = Theme.SubText
    dSub.Text = W.Subtitle
    W._drawings.sub = dSub

    -- Close button
    local dClose = H.NewSquare(13, true, 4)
    dClose.Color = Theme.CloseBtn
    W._drawings.close = dClose

    local dCloseX1 = H.NewLine(14, 2)
    dCloseX1.Color = Theme.Text
    W._drawings.closeX1 = dCloseX1

    local dCloseX2 = H.NewLine(14, 2)
    dCloseX2.Color = Theme.Text
    W._drawings.closeX2 = dCloseX2

    -- Minimize button
    local dMin = H.NewSquare(13, true, 4)
    dMin.Color = Theme.MinimizeBtn
    W._drawings.min = dMin

    local dMinLine = H.NewLine(14, 2)
    dMinLine.Color = Theme.Text
    W._drawings.minLine = dMinLine

    -- Content area separator line
    local dSep = H.NewLine(12, 1)
    dSep.Color = Theme.Border
    W._drawings.sep = dSep

    -- ---- Update function ----
    W._update = function()
        if not W._running then return end

        local pos  = W._pos
        local size = W.Size
        local visible = W._open and not W._minimized
        local topOnly = W._open and W._minimized

        -- Background
        dBg.Position = pos
        dBg.Size = visible and size or H.Vec2(size.X, TOPBAR_H)
        dBg.Visible = W._open

        -- Top bar
        dTop.Position = pos
        dTop.Size = H.Vec2(size.X, TOPBAR_H)
        dTop.Visible = W._open

        dTopFill.Position = pos + H.Vec2(0, TOPBAR_H / 2)
        dTopFill.Size = H.Vec2(size.X, TOPBAR_H / 2)
        dTopFill.Visible = W._open

        -- Sidebar
        dSide.Position = pos + H.Vec2(0, TOPBAR_H)
        dSide.Size = H.Vec2(SIDEBAR_W, size.Y - TOPBAR_H)
        dSide.Visible = visible

        dSideBorder.Position = pos + H.Vec2(SIDEBAR_W, TOPBAR_H)
        dSideBorder.Size = H.Vec2(1, size.Y - TOPBAR_H)
        dSideBorder.Visible = visible

        -- Title
        dTitle.Position = pos + H.Vec2(PAD + 4, TOPBAR_H / 2 - Theme.TitleSize / 2)
        dTitle.Visible = W._open

        -- Subtitle
        if W.Subtitle ~= "" then
            dSub.Position = dTitle.Position + H.Vec2(H.TextSize(W.Title, Theme.TitleSize).X + 8, 2)
            dSub.Visible = W._open
        else
            dSub.Visible = false
        end

        -- Close button (top right)
        local btnSize = H.Vec2(18, 18)
        local closePos = pos + H.Vec2(size.X - btnSize.X - PAD, TOPBAR_H / 2 - btnSize.Y / 2)
        dClose.Position = closePos
        dClose.Size = btnSize
        dClose.Visible = W._open

        -- X lines on close
        dCloseX1.From = closePos + H.Vec2(4, 4)
        dCloseX1.To   = closePos + H.Vec2(btnSize.X - 4, btnSize.Y - 4)
        dCloseX1.Visible = W._open

        dCloseX2.From = closePos + H.Vec2(btnSize.X - 4, 4)
        dCloseX2.To   = closePos + H.Vec2(4, btnSize.Y - 4)
        dCloseX2.Visible = W._open

        -- Minimize button
        local minPos = pos + H.Vec2(size.X - btnSize.X * 2 - PAD * 2, TOPBAR_H / 2 - btnSize.Y / 2)
        dMin.Position = minPos
        dMin.Size = btnSize
        dMin.Visible = W._open

        dMinLine.From = minPos + H.Vec2(4, btnSize.Y / 2)
        dMinLine.To   = minPos + H.Vec2(btnSize.X - 4, btnSize.Y / 2)
        dMinLine.Visible = W._open

        -- Separator
        dSep.From = pos + H.Vec2(0, TOPBAR_H)
        dSep.To   = pos + H.Vec2(size.X, TOPBAR_H)
        dSep.Visible = W._open

        -- Tabs
        local tabY = TOPBAR_H + PAD
        for i, tab in ipairs(W._tabs) do
            tab._update(i, tabY, visible)
            tabY = tabY + 32
        end
    end

    -- ---- Input ----
    local function handleDown(input)
        if not W._open then return end
        local pos = W._pos
        local size = W.Size
        local btnSize = H.Vec2(18, 18)

        -- Close
        local closePos = pos + H.Vec2(size.X - btnSize.X - PAD, TOPBAR_H / 2 - btnSize.Y / 2)
        if H.InRect(closePos, btnSize) then
            W._open = false
            return
        end

        -- Minimize
        local minPos = pos + H.Vec2(size.X - btnSize.X * 2 - PAD * 2, TOPBAR_H / 2 - btnSize.Y / 2)
        if H.InRect(minPos, btnSize) then
            W._minimized = not W._minimized
            return
        end

        -- Drag (topbar)
        if H.InRect(pos, H.Vec2(size.X - btnSize.X * 2 - PAD * 3, TOPBAR_H)) then
            W._dragging = true
            W._dragOffset = H.MousePos() - pos
        end

        -- Tab clicks
        if not W._minimized then
            for _, tab in ipairs(W._tabs) do
                tab._click()
            end
        end
    end

    local function handleUp()
        W._dragging = false
        -- widget releases
        for _, tab in ipairs(W._tabs) do
            for _, section in ipairs(tab._sections) do
                for _, widget in ipairs(section._widgets) do
                    if widget._release then widget._release() end
                end
            end
        end
    end

    local c1 = H.OnDown(handleDown)
    local c2 = H.OnUp(handleUp)
    local c3 = H.OnKey(function(input)
        if input.KeyCode == W.Key then
            W._open = not W._open
        end
    end)

    table.insert(W._connections, c1)
    table.insert(W._connections, c2)
    table.insert(W._connections, c3)

    -- ---- Main loop ----
    spawn(function()
        while W._running do
            task.wait()
            pcall(function()
                -- Dragging
                if W._dragging then
                    W._pos = H.MousePos() - W._dragOffset
                end

                W._update()

                -- Widget updates
                local visible = W._open and not W._minimized
                for _, tab in ipairs(W._tabs) do
                    local isActive = W._activeTab == tab
                    for _, section in ipairs(tab._sections) do
                        for _, widget in ipairs(section._widgets) do
                            if widget._tick then
                                widget._tick(visible and isActive)
                            end
                        end
                    end
                end
            end)
        end

        -- Cleanup
        for _, c in ipairs(W._connections) do pcall(function() c:Disconnect() end) end
        for _, d in pairs(W._drawings) do pcall(function() d:Remove() end) end
        for _, tab in ipairs(W._tabs) do
            for _, d in pairs(tab._drawings) do pcall(function() d:Remove() end) end
            for _, section in ipairs(tab._sections) do
                for _, d in pairs(section._drawings) do pcall(function() d:Remove() end) end
                for _, widget in ipairs(section._widgets) do
                    for _, d in pairs(widget._drawings) do pcall(function() d:Remove() end) end
                end
            end
        end
    end)

    -- ---- Methods ----
    function W:Toggle(bool)
        if bool == nil then
            self._open = not self._open
        else
            self._open = bool
        end
    end

    function W:Unload()
        self._running = false
    end

    function W:Tab(opts)
        opts = opts or {}
        local T = {}
        T._title    = opts.Title or "Tab"
        T._window   = W
        T._sections = {}
        T._drawings = {}
        T._active   = false

        local dBase = H.NewSquare(12, true, Theme.Corner)
        T._drawings.base = dBase

        local dTitle = H.NewText(13, Theme.FontSize, true)
        dTitle.Color = Theme.Text
        dTitle.Text  = T._title
        T._drawings.title = dTitle

        local dIndicator = H.NewSquare(13, true, 2)
        dIndicator.Color = Theme.Accent
        T._drawings.indicator = dIndicator

        T._update = function(index, tabY, visible)
            local wpos = W._pos
            local isActive = W._activeTab == T

            dBase.Position = wpos + H.Vec2(PAD / 2, tabY)
            dBase.Size     = H.Vec2(SIDEBAR_W - PAD, 26)
            dBase.Color    = isActive and Theme.TabActive or Theme.Sidebar
            dBase.Corner   = Theme.Corner
            dBase.Visible  = visible

            dTitle.Position = dBase.Position + H.Vec2(16, 5)
            dTitle.Color    = isActive and Theme.Text or Theme.SubText
            dTitle.Visible  = visible

            dIndicator.Position = dBase.Position + H.Vec2(4, 7)
            dIndicator.Size     = H.Vec2(3, 12)
            dIndicator.Visible  = visible and isActive

            -- Update sections
            if visible and isActive then
                local contentX = wpos.X + SIDEBAR_W + PAD
                local contentY = wpos.Y + TOPBAR_H + PAD
                local contentW = W.Size.X - SIDEBAR_W - PAD * 2

                -- Layout sections: pair them side by side if they are paired
                local i = 1
                local rowY = contentY
                while i <= #T._sections do
                    local s1 = T._sections[i]
                    local s2 = T._sections[i + 1]

                    if s1._paired and s2 and s2._paired and s1._pairGroup == s2._pairGroup then
                        -- Side by side
                        local halfW = (contentW - PAD) / 2
                        s1._update(contentX, rowY, halfW)
                        s2._update(contentX + halfW + PAD, rowY, halfW)
                        local h = math.max(s1._height, s2._height)
                        rowY = rowY + h + PAD
                        i = i + 2
                    else
                        -- Full width
                        s1._update(contentX, rowY, contentW)
                        rowY = rowY + s1._height + PAD
                        i = i + 1
                    end
                end
            else
                for _, s in ipairs(T._sections) do
                    s._hide()
                end
            end
        end

        T._click = function()
            local wpos = W._pos
            local tabY = TOPBAR_H + PAD
            for idx, tab in ipairs(W._tabs) do
                local bpos = wpos + H.Vec2(PAD / 2, tabY)
                local bsize = H.Vec2(SIDEBAR_W - PAD, 26)
                if tab == T and H.InRect(bpos, bsize) then
                    W._activeTab = T
                end
                tabY = tabY + 32
            end
            -- widget clicks
            if W._activeTab == T then
                for _, s in ipairs(T._sections) do
                    s._click()
                end
            end
        end

        -- ---- Section ----
        local function makeSection(sopts)
            sopts = sopts or {}
            local S = {}
            S._title    = sopts.Title or ""
            S._tab      = T
            S._widgets  = {}
            S._drawings = {}
            S._height   = 0
            S._paired   = false
            S._pairGroup = nil

            local dBase = H.NewSquare(14, true, Theme.Corner)
            dBase.Color = Theme.Section
            S._drawings.base = dBase

            local dHeader = H.NewSquare(15, true, Theme.Corner)
            dHeader.Color = Theme.SectionHeader
            S._drawings.header = dHeader

            local dHeaderFill = H.NewSquare(15, true, 0)
            dHeaderFill.Color = Theme.SectionHeader
            S._drawings.headerFill = dHeaderFill

            local dTitle = H.NewText(16, 12, true)
            dTitle.Color = Theme.SubText
            dTitle.Text  = S._title
            S._drawings.title = dTitle

            S._update = function(x, y, w)
                local HEADER_H = S._title ~= "" and 28 or 0
                local innerPad = PAD

                -- Calculate total height from widgets
                local totalWidgetH = HEADER_H + innerPad
                for _, widget in ipairs(S._widgets) do
                    totalWidgetH = totalWidgetH + widget._height + innerPad / 2
                end
                totalWidgetH = totalWidgetH + innerPad / 2
                S._height = math.max(totalWidgetH, 50)

                -- Base
                dBase.Position = H.Vec2(x, y)
                dBase.Size     = H.Vec2(w, S._height)
                dBase.Visible  = true

                -- Header
                if S._title ~= "" then
                    dHeader.Position = H.Vec2(x, y)
                    dHeader.Size     = H.Vec2(w, HEADER_H)
                    dHeader.Corner   = Theme.Corner
                    dHeader.Visible  = true

                    dHeaderFill.Position = H.Vec2(x, y + HEADER_H / 2)
                    dHeaderFill.Size     = H.Vec2(w, HEADER_H / 2)
                    dHeaderFill.Visible  = true

                    dTitle.Position = H.Vec2(x + innerPad, y + HEADER_H / 2 - 6)
                    dTitle.Visible  = true
                else
                    dHeader.Visible     = false
                    dHeaderFill.Visible = false
                    dTitle.Visible      = false
                end

                -- Widgets
                local widgetY = y + HEADER_H + innerPad
                for _, widget in ipairs(S._widgets) do
                    widget._update(x + innerPad, widgetY, w - innerPad * 2)
                    widgetY = widgetY + widget._height + innerPad / 2
                end
            end

            S._hide = function()
                for _, d in pairs(S._drawings) do pcall(function() d.Visible = false end) end
                for _, widget in ipairs(S._widgets) do
                    for _, d in pairs(widget._drawings) do pcall(function() d.Visible = false end) end
                end
            end

            S._click = function()
                for _, widget in ipairs(S._widgets) do
                    if widget._click then widget._click() end
                end
            end

            -- ========================
            -- WIDGETS
            -- ========================

            -- LABEL
            function S:Label(wopts)
                wopts = wopts or {}
                local widget = { _drawings = {}, _height = 20 }
                widget._text = wopts.Title or ""

                local dText = H.NewText(17, Theme.FontSize, true)
                dText.Color = Theme.SubText
                dText.Text  = widget._text
                widget._drawings.text = dText

                widget._update = function(x, y, w)
                    dText.Position = H.Vec2(x, y + 3)
                    dText.Visible  = true
                end

                widget._click = function() end

                table.insert(S._widgets, widget)

                local ref = {}
                function ref:Get() return widget._text end
                function ref:Set(txt)
                    widget._text = txt
                    dText.Text = txt
                end
                return ref
            end

            -- BUTTON
            function S:Button(wopts, callback)
                wopts = wopts or {}
                callback = callback or function() end
                local widget = { _drawings = {}, _height = 28 }
                widget._title = wopts.Title or "Button"

                local dBase = H.NewSquare(17, true, Theme.Corner)
                dBase.Color = Theme.TabActive
                widget._drawings.base = dBase

                local dText = H.NewText(18, Theme.FontSize, true)
                dText.Color = Theme.Text
                dText.Text  = widget._title
                widget._drawings.text = dText

                local dArrow = H.NewText(18, Theme.FontSize, true)
                dArrow.Color = Theme.SubText
                dArrow.Text  = ">"
                widget._drawings.arrow = dArrow

                widget._update = function(x, y, w)
                    dBase.Position = H.Vec2(x, y)
                    dBase.Size     = H.Vec2(w, 26)
                    dBase.Visible  = true

                    dText.Position = H.Vec2(x + 8, y + 5)
                    dText.Visible  = true

                    dArrow.Position = H.Vec2(x + w - 18, y + 5)
                    dArrow.Visible  = true
                end

                widget._click = function()
                    if not dBase.Visible then return end
                    if H.InRect(dBase.Position, dBase.Size) then
                        callback()
                    end
                end

                table.insert(S._widgets, widget)
                return widget
            end

            -- TOGGLE
            function S:Toggle(wopts, callback)
                wopts = wopts or {}
                callback = callback or function() end
                local widget = { _drawings = {}, _height = 28 }
                widget._value = wopts.Default or false
                widget._title = wopts.Title or "Toggle"

                local dText = H.NewText(17, Theme.FontSize, true)
                dText.Color = Theme.Text
                dText.Text  = widget._title
                widget._drawings.text = dText

                -- Toggle track
                local dTrack = H.NewSquare(17, true, 8)
                widget._drawings.track = dTrack

                -- Toggle knob
                local dKnob = H.NewCircle(18, true)
                dKnob.Color = Color3.fromRGB(255, 255, 255)
                dKnob.NumSides = 30
                dKnob.Radius = 7
                widget._drawings.knob = dKnob

                widget._update = function(x, y, w)
                    dText.Position = H.Vec2(x, y + 5)
                    dText.Visible  = true

                    local trackW = 36
                    local trackH = 18
                    local trackX = x + w - trackW
                    local trackY = y + 4

                    dTrack.Position = H.Vec2(trackX, trackY)
                    dTrack.Size     = H.Vec2(trackW, trackH)
                    dTrack.Color    = widget._value and Theme.ToggleOn or Theme.ToggleOff
                    dTrack.Corner   = 9
                    dTrack.Visible  = true

                    local knobX = widget._value and (trackX + trackW - trackH + 1) or (trackX + 1)
                    dKnob.Position = H.Vec2(knobX + trackH / 2 - 1, trackY + trackH / 2)
                    dKnob.Visible  = true
                end

                widget._click = function()
                    if not dTrack.Visible then return end
                    if H.InRect(dTrack.Position, dTrack.Size) then
                        widget._value = not widget._value
                        callback(widget._value)
                    end
                end

                table.insert(S._widgets, widget)

                local ref = {}
                function ref:Get() return widget._value end
                function ref:Set(bool)
                    widget._value = bool
                    callback(bool)
                end
                return ref
            end

            -- SLIDER
            function S:Slider(wopts, callback)
                wopts = wopts or {}
                callback = callback or function() end
                local widget = { _drawings = {}, _height = 40, _sliding = false }
                widget._min    = wopts.Min or 0
                widget._max    = wopts.Max or 100
                widget._step   = wopts.Step or 1
                widget._value  = wopts.Default or widget._min
                widget._suffix = wopts.Suffix or ""
                widget._title  = wopts.Title or "Slider"

                local dTitle = H.NewText(17, Theme.FontSize, true)
                dTitle.Color = Theme.Text
                dTitle.Text  = widget._title
                widget._drawings.title = dTitle

                local dTrack = H.NewSquare(17, true, 4)
                dTrack.Color = Theme.SliderBg
                widget._drawings.track = dTrack

                local dFill = H.NewSquare(18, true, 4)
                dFill.Color = Theme.SliderFill
                widget._drawings.fill = dFill

                local dValue = H.NewText(19, 11, true)
                dValue.Color = Theme.Text
                widget._drawings.value = dValue

                widget._update = function(x, y, w)
                    dTitle.Position = H.Vec2(x, y + 2)
                    dTitle.Visible  = true

                    local trackY = y + 20
                    dTrack.Position = H.Vec2(x, trackY)
                    dTrack.Size     = H.Vec2(w, 12)
                    dTrack.Visible  = true

                    local pct = math.clamp((widget._value - widget._min) / (widget._max - widget._min), 0, 1)
                    dFill.Position = H.Vec2(x, trackY)
                    dFill.Size     = H.Vec2(math.max(w * pct, 8), 12)
                    dFill.Visible  = true

                    local valText = tostring(widget._value) .. widget._suffix
                    dValue.Text     = valText
                    dValue.Position = H.Vec2(x + w / 2 - #valText * 3, trackY - 1)
                    dValue.Visible  = true

                    if widget._sliding then
                        local rawPct = math.clamp((Mouse.X - x) / w, 0, 1)
                        local rawVal = widget._min + (widget._max - widget._min) * rawPct
                        local stepped = math.floor(rawVal / widget._step + 0.5) * widget._step
                        local clamped = math.clamp(stepped, widget._min, widget._max)
                        local fmt = "%." .. math.max(0, -math.floor(math.log10(widget._step + 0.0001))) .. "f"
                        clamped = tonumber(string.format(fmt, clamped))
                        if clamped ~= widget._value then
                            widget._value = clamped
                            callback(clamped)
                        end
                    end
                end

                widget._click = function()
                    if not dTrack.Visible then return end
                    if H.InRect(dTrack.Position, dTrack.Size) then
                        widget._sliding = true
                    end
                end

                widget._release = function()
                    widget._sliding = false
                end

                table.insert(S._widgets, widget)

                local ref = {}
                function ref:Get() return widget._value end
                function ref:Set(num)
                    widget._value = math.clamp(num, widget._min, widget._max)
                    callback(widget._value)
                end
                return ref
            end

            -- DROPDOWN
            function S:Dropdown(wopts, callback)
                wopts = wopts or {}
                callback = callback or function() end
                local widget = { _drawings = {}, _height = 32, _open = false, _optDrawings = {} }
                widget._title   = wopts.Title or "Dropdown"
                widget._options = wopts.Options or {}
                widget._value   = wopts.Default or widget._options[1]
                widget._scroll  = 0
                widget._maxShow = 4

                local dBase = H.NewSquare(17, true, Theme.Corner)
                dBase.Color = Theme.TabActive
                widget._drawings.base = dBase

                local dText = H.NewText(18, Theme.FontSize, true)
                dText.Color = Theme.Text
                widget._drawings.text = dText

                local dArrow = H.NewText(18, Theme.FontSize, true)
                dArrow.Color = Theme.SubText
                widget._drawings.arrow = dArrow

                -- Option drawings (scrollable, show up to maxShow)
                for i = 1, widget._maxShow do
                    local ob = H.NewSquare(20, true, Theme.Corner)
                    ob.Color = Theme.TabActive
                    local ot = H.NewText(21, Theme.FontSize, true)
                    ot.Color = Theme.Text
                    table.insert(widget._optDrawings, { base = ob, text = ot })
                end

                -- Scroll arrows
                local dScrollUp = H.NewText(22, 11, true)
                dScrollUp.Text = "▲"
                dScrollUp.Color = Theme.SubText
                widget._drawings.scrollUp = dScrollUp

                local dScrollDown = H.NewText(22, 11, true)
                dScrollDown.Text = "▼"
                dScrollDown.Color = Theme.SubText
                widget._drawings.scrollDown = dScrollDown

                widget._update = function(x, y, w)
                    widget._height = widget._open and (32 + widget._maxShow * 26 + 4) or 32

                    dBase.Position = H.Vec2(x, y)
                    dBase.Size     = H.Vec2(w, 28)
                    dBase.Visible  = true

                    dText.Text     = widget._title .. ": " .. (widget._value or "")
                    dText.Position = H.Vec2(x + 8, y + 7)
                    dText.Visible  = true

                    dArrow.Text     = widget._open and "▲" or "▼"
                    dArrow.Position = H.Vec2(x + w - 18, y + 7)
                    dArrow.Visible  = true

                    -- Options
                    local showCount = math.min(widget._maxShow, #widget._options)
                    local needsScroll = #widget._options > widget._maxShow

                    for i = 1, widget._maxShow do
                        local od = widget._optDrawings[i]
                        local optIdx = i + widget._scroll
                        local opt = widget._options[optIdx]

                        if widget._open and opt then
                            local optY = y + 28 + (i - 1) * 26 + 2
                            od.base.Position = H.Vec2(x, optY)
                            od.base.Size     = H.Vec2(w, 24)
                            od.base.Color    = (opt == widget._value) and Theme.Accent or Theme.Section
                            od.base.Visible  = true

                            od.text.Text     = opt
                            od.text.Position = H.Vec2(x + 8, optY + 5)
                            od.text.Visible  = true
                        else
                            od.base.Visible = false
                            od.text.Visible = false
                        end
                    end

                    -- Scroll arrows
                    if widget._open and needsScroll then
                        local listH = widget._maxShow * 26
                        dScrollUp.Position   = H.Vec2(x + w - 16, y + 30)
                        dScrollDown.Position = H.Vec2(x + w - 16, y + 28 + listH - 14)
                        dScrollUp.Visible    = widget._scroll > 0
                        dScrollDown.Visible  = widget._scroll < #widget._options - widget._maxShow
                    else
                        dScrollUp.Visible   = false
                        dScrollDown.Visible = false
                    end
                end

                widget._click = function()
                    if not dBase.Visible then return end

                    -- Toggle open
                    if H.InRect(dBase.Position, dBase.Size) then
                        widget._open = not widget._open
                        return
                    end

                    -- Scroll up
                    if dScrollUp.Visible and H.InRect(dScrollUp.Position, H.Vec2(14, 14)) then
                        widget._scroll = math.max(0, widget._scroll - 1)
                        return
                    end

                    -- Scroll down
                    if dScrollDown.Visible and H.InRect(dScrollDown.Position, H.Vec2(14, 14)) then
                        widget._scroll = math.min(#widget._options - widget._maxShow, widget._scroll + 1)
                        return
                    end

                    -- Select option
                    if widget._open then
                        for i = 1, widget._maxShow do
                            local od = widget._optDrawings[i]
                            if od.base.Visible and H.InRect(od.base.Position, od.base.Size) then
                                local optIdx = i + widget._scroll
                                local opt = widget._options[optIdx]
                                if opt then
                                    widget._value = opt
                                    widget._open = false
                                    callback(opt)
                                end
                            end
                        end
                    end
                end

                table.insert(S._widgets, widget)

                local ref = {}
                function ref:Get() return widget._value end
                function ref:Set(val)
                    if table.find(widget._options, val) then
                        widget._value = val
                        callback(val)
                    end
                end
                return ref
            end

            -- MULTIDROPDOWN
            function S:MultiDropdown(wopts, callback)
                wopts = wopts or {}
                callback = callback or function() end
                local widget = { _drawings = {}, _height = 32, _open = false, _optDrawings = {} }
                widget._title   = wopts.Title or "MultiDropdown"
                widget._options = wopts.Options or {}
                widget._value   = wopts.Default or {}
                widget._scroll  = 0
                widget._maxShow = 4

                local dBase = H.NewSquare(17, true, Theme.Corner)
                dBase.Color = Theme.TabActive
                widget._drawings.base = dBase

                local dText = H.NewText(18, Theme.FontSize, true)
                dText.Color = Theme.Text
                widget._drawings.text = dText

                local dArrow = H.NewText(18, Theme.FontSize, true)
                dArrow.Color = Theme.SubText
                widget._drawings.arrow = dArrow

                for i = 1, widget._maxShow do
                    local ob = H.NewSquare(20, true, Theme.Corner)
                    ob.Color = Theme.Section
                    local ot = H.NewText(21, Theme.FontSize, true)
                    ot.Color = Theme.Text
                    local oc = H.NewSquare(21, true, 2)
                    table.insert(widget._optDrawings, { base = ob, text = ot, check = oc })
                end

                local dScrollUp = H.NewText(22, 11, true)
                dScrollUp.Text = "▲"
                dScrollUp.Color = Theme.SubText
                widget._drawings.scrollUp = dScrollUp

                local dScrollDown = H.NewText(22, 11, true)
                dScrollDown.Text = "▼"
                dScrollDown.Color = Theme.SubText
                widget._drawings.scrollDown = dScrollDown

                widget._update = function(x, y, w)
                    widget._height = widget._open and (32 + widget._maxShow * 26 + 4) or 32

                    local selectedText = #widget._value > 0 and table.concat(widget._value, ", ") or "None"
                    dBase.Position = H.Vec2(x, y)
                    dBase.Size     = H.Vec2(w, 28)
                    dBase.Visible  = true

                    dText.Text     = widget._title .. ": " .. selectedText
                    dText.Position = H.Vec2(x + 8, y + 7)
                    dText.Visible  = true

                    dArrow.Text     = widget._open and "▲" or "▼"
                    dArrow.Position = H.Vec2(x + w - 18, y + 7)
                    dArrow.Visible  = true

                    local needsScroll = #widget._options > widget._maxShow

                    for i = 1, widget._maxShow do
                        local od = widget._optDrawings[i]
                        local optIdx = i + widget._scroll
                        local opt = widget._options[optIdx]
                        local selected = opt and table.find(widget._value, opt)

                        if widget._open and opt then
                            local optY = y + 28 + (i - 1) * 26 + 2
                            od.base.Position = H.Vec2(x, optY)
                            od.base.Size     = H.Vec2(w, 24)
                            od.base.Color    = selected and Theme.Accent or Theme.Section
                            od.base.Visible  = true

                            od.text.Text     = opt
                            od.text.Position = H.Vec2(x + 28, optY + 5)
                            od.text.Visible  = true

                            od.check.Position = H.Vec2(x + 6, optY + 5)
                            od.check.Size     = H.Vec2(14, 14)
                            od.check.Color    = selected and Theme.Accent or Theme.SliderBg
                            od.check.Corner   = 3
                            od.check.Visible  = true
                        else
                            od.base.Visible  = false
                            od.text.Visible  = false
                            od.check.Visible = false
                        end
                    end

                    if widget._open and needsScroll then
                        local listH = widget._maxShow * 26
                        dScrollUp.Position   = H.Vec2(x + w - 16, y + 30)
                        dScrollDown.Position = H.Vec2(x + w - 16, y + 28 + listH - 14)
                        dScrollUp.Visible    = widget._scroll > 0
                        dScrollDown.Visible  = widget._scroll < #widget._options - widget._maxShow
                    else
                        dScrollUp.Visible   = false
                        dScrollDown.Visible = false
                    end
                end

                widget._click = function()
                    if not dBase.Visible then return end

                    if H.InRect(dBase.Position, dBase.Size) then
                        widget._open = not widget._open
                        return
                    end

                    if dScrollUp.Visible and H.InRect(dScrollUp.Position, H.Vec2(14, 14)) then
                        widget._scroll = math.max(0, widget._scroll - 1)
                        return
                    end

                    if dScrollDown.Visible and H.InRect(dScrollDown.Position, H.Vec2(14, 14)) then
                        widget._scroll = math.min(#widget._options - widget._maxShow, widget._scroll + 1)
                        return
                    end

                    if widget._open then
                        for i = 1, widget._maxShow do
                            local od = widget._optDrawings[i]
                            if od.base.Visible and H.InRect(od.base.Position, od.base.Size) then
                                local optIdx = i + widget._scroll
                                local opt = widget._options[optIdx]
                                if opt then
                                    local idx = table.find(widget._value, opt)
                                    if idx then
                                        table.remove(widget._value, idx)
                                    else
                                        table.insert(widget._value, opt)
                                    end
                                    callback(widget._value)
                                end
                            end
                        end
                    end
                end

                table.insert(S._widgets, widget)

                local ref = {}
                function ref:Get() return widget._value end
                function ref:Set(tbl) widget._value = tbl; callback(tbl) end
                function ref:Add(opt)
                    if table.find(widget._options, opt) and not table.find(widget._value, opt) then
                        table.insert(widget._value, opt); callback(widget._value)
                    end
                end
                function ref:Remove(opt)
                    local idx = table.find(widget._value, opt)
                    if idx then table.remove(widget._value, idx); callback(widget._value) end
                end
                function ref:Toggle(opt)
                    if table.find(widget._value, opt) then self:Remove(opt) else self:Add(opt) end
                end
                return ref
            end

            -- KEYBIND
            function S:Keybind(wopts, onPress, onChanged)
                wopts = wopts or {}
                onPress   = onPress   or function() end
                onChanged = onChanged or function() end
                local widget = { _drawings = {}, _height = 28 }
                widget._title    = wopts.Title or "Keybind"
                widget._key      = wopts.Key or nil
                widget._changing = false
                widget._changeT  = 0

                local dTitle = H.NewText(17, Theme.FontSize, true)
                dTitle.Color = Theme.Text
                dTitle.Text  = widget._title
                widget._drawings.title = dTitle

                local dKey = H.NewSquare(17, true, 4)
                dKey.Color = Theme.TabActive
                widget._drawings.keyBase = dKey

                local dKeyText = H.NewText(18, 11, true)
                dKeyText.Color = Theme.Text
                widget._drawings.keyText = dKeyText

                local conn = H.OnKey(function(input)
                    if input.KeyCode == widget._key and not widget._changing then
                        onPress()
                    end
                    if widget._changing and (os.clock() - widget._changeT) > 0.1 then
                        widget._changing = false
                        if input.KeyCode == Enum.KeyCode.Escape then
                            widget._key = nil
                        else
                            widget._key = input.KeyCode
                        end
                        onChanged(widget._key)
                    end
                end)
                table.insert(S._tab._window._connections, conn)

                widget._update = function(x, y, w)
                    dTitle.Position = H.Vec2(x, y + 5)
                    dTitle.Visible  = true

                    local keyStr = widget._changing and "..." or H.KeyName(widget._key)
                    dKeyText.Text  = keyStr
                    local keyW = math.max(40, #keyStr * 8 + 10)
                    dKey.Position  = H.Vec2(x + w - keyW, y + 2)
                    dKey.Size      = H.Vec2(keyW, 22)
                    dKey.Visible   = true
                    dKeyText.Position = H.Vec2(x + w - keyW + 5, y + 6)
                    dKeyText.Visible  = true
                end

                widget._click = function()
                    if not dKey.Visible then return end
                    if H.InRect(dKey.Position, dKey.Size) then
                        widget._changing = true
                        widget._changeT  = os.clock()
                    end
                end

                table.insert(S._widgets, widget)
                return widget
            end

            return S
        end

        -- ---- Tab methods ----

        -- Full width section
        function T:Section(sopts)
            local s = makeSection(sopts)
            s._paired = false
            table.insert(T._sections, s)
            return s
        end

        -- Side by side row — returns Left, Right
        local _pairCounter = 0
        function T:Row(leftOpts, rightOpts)
            _pairCounter = _pairCounter + 1
            local group = _pairCounter

            local sL = makeSection(leftOpts)
            sL._paired    = true
            sL._pairGroup = group
            table.insert(T._sections, sL)

            local sR = makeSection(rightOpts)
            sR._paired    = true
            sR._pairGroup = group
            table.insert(T._sections, sR)

            return sL, sR
        end

        if not W._activeTab then
            W._activeTab = T
        end

        table.insert(W._tabs, T)
        return T
    end

    return W
end
